# =============================================================================
# Godspeed — .env (fill in <...> values before running)
# =============================================================================

# --- JIRA ---
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEYS=
JIRA_WEBHOOK_SECRET=

# --- CONFLUENCE ---
CONFLUENCE_BASE_URL=https://your-org.atlassian.net
CONFLUENCE_EMAIL=
CONFLUENCE_TOKEN=
CONFLUENCE_SPACES=
CONFLUENCE_WEBHOOK_SECRET=

# --- FILE AGENT ---
FILE_WATCH_FOLDER=./data_sources
MAX_WORDS_PER_CHUNK=400

# --- TEAM ---
TEAM_ID=default

# --- QDRANT ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=knowledge_base

# --- REDIS ---
REDIS_URL=redis://localhost:6379/0

# --- SUPABASE ---
SUPABASE_URL=
SUPABASE_KEY=

# --- GOOGLE AI ---
GOOGLE_API_KEY=

# --- GITHUB ---
GITHUB_TOKEN=
GITHUB_PATH_FILTER=docs/
GITHUB_BRANCH=main

# --- Model overrides (optional — defaults shown) ---
PLANNER_MODEL=gemini-2.5-pro
SYNTHESISER_MODEL=gemini-2.5-pro
SUMMARISER_MODEL=gemini-2.5-flash
GUARDRAIL_MODEL=gemini-2.5-flash
CAG_MODEL=gemini-2.5-pro
