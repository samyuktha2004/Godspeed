# ── Frontend environment variables ───────────────────────────────────────────
# Copy this file to .env and fill in values before running `pnpm dev`.
# All VITE_ vars are bundled into the client — do NOT put secrets here.

# Base URL of the FastAPI backend (no trailing slash)
VITE_API_BASE_URL=http://localhost:8000

# WebSocket base URL (replace http with ws automatically in SystemLogs.tsx,
# but this is used explicitly by useGraphStream and useNotifications)
VITE_WS_BASE_URL=ws://localhost:8000
